# Copia este archivo a `.env` y rellena tu clave.
# docker compose lo carga automáticamente.

# Clave de OpenRouter (usado para agente + STT).
OPENROUTER_API_KEY=your-openrouter-api-key-here


# Opcionales:
# Base URL de OpenRouter (por defecto).
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Modelo del agente (function calling).
REFERIA_OPENAI_MODEL=openai/gpt-4o-mini
# Modelo de transcripción de audio.
REFERIA_STT_MODEL=openai/whisper-large-v3-turbo
# Motor del agente: openai | claude | stub
REFERIA_ENGINE=openai
